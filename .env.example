# Plantilla de variables de entorno. Copiar a .env y rellenar.
# El script scripts/bootstrap.sh genera estos valores si falta el .env.

# Credenciales del admin de Jenkins (UI web).
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=changeme

# Llave pública SSH del controller, en formato single-line (ssh-ed25519 ...).
# Debe corresponderse con la privada en infrastructure/secrets/controller_ssh_key.
CONTROLLER_SSH_PUBKEY=
